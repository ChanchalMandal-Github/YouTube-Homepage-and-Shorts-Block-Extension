{
  "manifest_version": 3,
  "name": "YouTube Infinite Scroll Block & Shorts Limiter",
  "version": "1.1",
  "description": "Customizable YouTube with Shorts limiting.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}